{
  "@context": {
    "schema": "https://schema.org/",
    "beckn": "https://schema.beckn.io/",
    "hct": "https://schema.beckn.io/HealthContract#",
    "sc": "https://schema.beckn.io/ServiceContract#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",

    "HealthContract": "hct:HealthContract",
    "HealthServiceType": "hct:HealthServiceType",
    "BookingChannel": "sc:BookingChannel",
    "CollectionPurpose": "hct:CollectionPurpose",
    "ArtifactType": "hct:ArtifactType",

    "ServiceContract": "sc:ServiceContract",

    "healthServiceType": {"@id": "hct:healthServiceType"},
    "campId": {"@id": "hct:campId"},
    "artifactAccessEndpoint": {"@id": "hct:artifactAccessEndpoint"},
    "inputArtifacts": {"@id": "hct:inputArtifacts", "@container": "@list"},
    "artifactRef": {"@id": "hct:artifactRef"},
    "artifactType": {"@id": "hct:artifactType"},
    "mimeType": {"@id": "hct:mimeType"},

    "consent": {"@id": "hct:consent", "@type": "@id"},
    "consentDocRef": {"@id": "hct:consentDocRef"},
    "consentId": {"@id": "hct:consentId"},
    "patientParticipantId": {"@id": "hct:patientParticipantId"},
    "consentStandard": {"@id": "hct:consentStandard"},
    "consentedAt": {"@id": "hct:consentedAt"},
    "consentedBy": {"@id": "hct:consentedBy"},
    "purposeOfCollection": {"@id": "hct:purposeOfCollection", "@container": "@set"},
    "dataRetentionDays": {"@id": "hct:dataRetentionDays"},
    "withdrawnAt": {"@id": "hct:withdrawnAt"},

    "bookingChannel": {"@id": "sc:bookingChannel"},
    "clientNotes": {"@id": "sc:clientNotes"},
    "cancellationReason": {"@id": "sc:cancellationReason"},
    "facilitatorId": {"@id": "sc:facilitatorId"},
    "reminderSentAt": {"@id": "sc:reminderSentAt"}
  }
}
