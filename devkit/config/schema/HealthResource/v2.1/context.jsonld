{
  "@context": {
    "schema": "https://schema.org/",
    "beckn": "https://schema.beckn.io/",
    "hr": "https://schema.beckn.io/HealthResource#",
    "sr": "https://schema.beckn.io/ServiceResource#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",

    "HealthResource": "hr:HealthResource",
    "HealthServiceType": "hr:HealthServiceType",
    "ClinicalDeliveryUnit": "hr:ClinicalDeliveryUnit",
    "PrerequisiteType": "hr:PrerequisiteType",

    "ServiceResource": "sr:ServiceResource",
    "ServiceCoverageArea": "sr:ServiceCoverageArea",
    "ServiceAvailabilitySlot": "sr:ServiceAvailabilitySlot",
    "ServiceUnit": "sr:ServiceUnit",
    "DayOfWeek": "sr:DayOfWeek",

    "healthServiceType": {"@id": "hr:healthServiceType"},
    "clinicalDeliveryUnit": {"@id": "hr:clinicalDeliveryUnit"},
    "clinicalValidation": {"@id": "hr:clinicalValidation"},
    "accreditationBody": {"@id": "hr:accreditationBody"},
    "registrationNumber": {"@id": "hr:registrationNumber"},
    "specialty": {"@id": "hr:specialty"},
    "validUntil": {"@id": "hr:validUntil"},
    "servicePrerequisites": {"@id": "hr:servicePrerequisites", "@container": "@list"},
    "prerequisiteType": {"@id": "hr:prerequisiteType"},
    "mandatory": {"@id": "hr:mandatory"},
    "analyticsEngineSpecs": {"@id": "hr:analyticsEngineSpecs"},
    "modelName": {"@id": "hr:modelName"},
    "modelVersion": {"@id": "hr:modelVersion"},
    "confidenceThreshold": {"@id": "hr:confidenceThreshold"},
    "supportedInputFormats": {"@id": "hr:supportedInputFormats", "@container": "@list"},
    "regulatoryApproval": {"@id": "hr:regulatoryApproval"},

    "serviceUnit": {"@id": "sr:serviceUnit"},
    "coverageArea": {"@id": "sr:coverageArea", "@container": "@list"},
    "capacityPerDay": {"@id": "sr:capacityPerDay"},
    "capacityPerWeek": {"@id": "sr:capacityPerWeek"},
    "availabilitySchedule": {"@id": "sr:availabilitySchedule", "@container": "@list"},
    "availabilityRecurrenceRule": {"@id": "sr:availabilityRecurrenceRule"},
    "minimumBookingAdvanceHours": {"@id": "sr:minimumBookingAdvanceHours"},
    "languagesSupported": {"@id": "sr:languagesSupported", "@container": "@list"},
    "isoCode": {"@id": "sr:isoCode"},
    "region": {"@id": "sr:region"},
    "country": {"@id": "sr:country"},
    "coverageRadiusKm": {"@id": "sr:coverageRadiusKm"},
    "dayOfWeek": {"@id": "sr:dayOfWeek"},
    "startTime": {"@id": "sr:startTime"},
    "endTime": {"@id": "sr:endTime"}
  }
}
