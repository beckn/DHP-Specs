{
  "@context": {
    "schema": "https://schema.org/",
    "beckn": "https://schema.beckn.io/",
    "hpa": "https://schema.beckn.io/HealthParticipant#",
    "sp": "https://schema.beckn.io/ServiceParticipant#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",

    "HealthParticipant": "hpa:HealthParticipant",
    "ParticipantRole": "hpa:ParticipantRole",
    "Gender": "hpa:Gender",

    "participantRole": {"@id": "hpa:participantRole"},
    "healthIds": {"@id": "hpa:healthIds", "@container": "@list"},
    "system": {"@id": "hpa:system"},
    "value": {"@id": "hpa:value"},
    "dateOfBirth": {"@id": "hpa:dateOfBirth"},
    "gender": {"@id": "hpa:gender"},
    "primaryLanguage": {"@id": "hpa:primaryLanguage"},
    "specialistAccreditation": {"@id": "hpa:specialistAccreditation"},
    "accreditationBody": {"@id": "hpa:accreditationBody"},
    "registrationNumber": {"@id": "hpa:registrationNumber"},
    "specialty": {"@id": "hpa:specialty"},
    "validUntil": {"@id": "hpa:validUntil"},

    "credentialRefs": {"@id": "sp:credentialRefs", "@container": "@list"}
  }
}
